        ],
        "contained": [
          {
            "resourceType": "Group",
            "id": "eligibility-criteria",
            "meta": {
              "versionId": "1",
              "lastUpdated": "2023-01-01T00:00:00Z"
            },
            "characteristic": [
              {
                "exclude": false,
                "valueCodeableConcept": "<p>Histologic confirmation of one of the following solid tumors that is advanced (unresectable or metastatic) for dose escalation or cohort expansion:<usdm:tag name=\"indic_1\"/>, <usdm:tag name=\"indic_2\"/>, <usdm:tag name=\"indic_3\"/></p>",
                "valueReference": {
                  "reference": "ExtensionClass_ExpRespNode_1",
                  "type": "Group"
                }
              },
              {
                "exclude": true,
                "valueCodeableConcept": "<p>Subjects with active autoimmune disease, uncontrolled or significant cardiovascular disease</p>"
              },
              {
                "exclude": true,
                "valueCodeableConcept": "<p>Prior therapy with anti- Cytotoxic T-Lymphocyte Antigen 4 (CTLA4) antibody or anti- Killer cell immunoglobulin-like receptor (KIR) antibody</p>"
              },
              {
                "exclude": true,
                "valueCodeableConcept": "<p>Grade 2 <usdm:tag name=\"contraIndic_2\"/></p>"
              },
              {
                "exclude": false,
                "valueCodeableConcept": "<p>At least one measurable lesion at baseline by Computed tomography (CT) or Magnetic resonance imaging (MRI) as per <usdm:tag name=\"bc_recist_1\"/></p>"
              },
              {
                "exclude": false,
                "valueCodeableConcept": "<p>Biopsies: Subjects in the melanoma cohort must have at least 1 tumor site that can be biopsied at acceptable clinical risk</p>"
              },
              {
                "exclude": false,
                "valueCodeableConcept": "<p><usdm:tag name=\"bc_ecog_1\"/> of 0 or 1</p>",
                "valueReference": {
                  "reference": "ExtensionClass_ExpResp_1",
                  "type": "Group"
                }
              },
              {
                "exclude": false,
                "valueCodeableConcept": "<p>Estimated life expectancy of >= 12 weeks</p>"
              },
              {
                "exclude": false,
                "valueCodeableConcept": "<p><usdm:tag name=\"bc_wbc_1\"/> &gt;=2000/&#181;L, <usdm:tag name=\"bc_neut_1\"/> &gt;=1500/&#181;L, <usdm:tag name=\"bc_plat_1\"/> &gt;= 100x1000/&#181;L, <usdm:tag name=\"bc_hgb_1\"/> &gt;= 8.5 g/dL, <usdm:tag name=\"bc_crcl_1\"/> &lt;= 1.5 X upper limit of normal (ULN) mL/min, <usdm:tag name=\"bc_alt_1\"/> and <usdm:tag name=\"bc_ast_1\"/> &lt;= 3x ULN</p>"
              },
              {
                "exclude": false,
                "valueCodeableConcept": "<p>Normal <usdm:tag name=\"bcCat_thyr_1\"/> or be on stable hormone supplementation</p>"
              },
              {
                "exclude": true,
                "valueCodeableConcept": "<p>Participation in any prior clinical study with BMS-936558 or ipilimumab that has overall survival listed as a primary/co-primary endpoint</p>"
              },
              {
                "exclude": true,
                "valueCodeableConcept": "<p>Subjects with known or suspected <usdm:tag name=\"contraIndic_1\"/></p>",
                "valueReference": {
                  "reference": "ExtensionClass_ExpResp_5",
                  "type": "Group"
                }
              }
            ],
            "combinationMethod": "all-of"
          },
